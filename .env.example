# Konfigurasi Port (Opsional, installer otomatis akan mencari yang kosong)
PORT=3000

# URL Koneksi Database PostgreSQL (WAJIB DIISI)
# Contoh format: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=postgresql://postgres:password123@localhost:5432/nexus_db

# Secret key untuk autentikasi Dashboard Admin
JWT_SECRET=ganti_dengan_secret_key_yang_aman
ADMIN_PASSWORD=ganti_dengan_password_admin_yang_aman
