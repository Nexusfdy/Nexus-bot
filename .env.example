# Security Secrets (Must be overridden in Production!)
JWT_SECRET=super_secret_jwt_key_here
ADMIN_PASSWORD=admin123

# Database Configuration (PostgreSQL)
# Recommended
DATABASE_URL=postgresql://user:password@host:5432/database

# Optional (Advanced)
# POSTGRES_HOST=
# POSTGRES_PORT=
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=