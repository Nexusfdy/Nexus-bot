# Security Secrets (Must be overridden in Production!)
JWT_SECRET=super_secret_jwt_key_here
ADMIN_PASSWORD=admin123

# Port Configuration
# Default port is 3000. If port 3000 is occupied, the installer will automatically pick the next available port and update this.
PORT=3000

# Database Configuration (PostgreSQL)
# Recommended
DATABASE_URL=postgresql://user:password@host:5432/database

# Optional (Advanced)
# POSTGRES_HOST=
# POSTGRES_PORT=
# POSTGRES_USER=
# POSTGRES_PASSWORD=
